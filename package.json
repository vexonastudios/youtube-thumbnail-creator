{
  "name": "sermonthumb",
  "version": "1.0.6",
  "description": "AI-powered sermon thumbnail maker for churches by Vexona Studios",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "eslint",
    "electron": "electron electron/main.js",
    "app": "electron electron/main.js",
    "build:app": "next build && electron-builder",
    "release": "next build && electron-builder --publish always"
  },
  "build": {
    "appId": "com.vexonastudios.sermonthumb",
    "productName": "SermonThumb",
    "copyright": "Copyright © 2025 Vexona Studios",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "!electron/node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app/.next/standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".next/static",
        "to": "app/.next/standalone/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public",
        "to": "app/.next/standalone/public",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/@img",
        "to": "app/.next/standalone/node_modules/@img",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/sharp",
        "to": "app/.next/standalone/node_modules/sharp",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/@ffmpeg-installer",
        "to": "app/.next/standalone/node_modules/@ffmpeg-installer",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.png",
      "signAndEditExecutable": false
    },
    "forceCodeSigning": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "SermonThumb"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "vexonastudios",
        "repo": "sermonthumb",
        "releaseType": "release"
      }
    ]
  },
  "author": "Vexona Studios",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google/generative-ai": "^0.24.1",
    "electron-updater": "^6.8.3",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^171.4.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "typescript": "^5",
    "wait-on": "^8.0.3"
  }
}
